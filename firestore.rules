rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isPrivilegedPortalOperator() {
      return signedIn() && (request.auth.token.admin == true || request.auth.token.custodian == true);
    }

    function isEventCreator() {
      return signedIn() && resource.data.createdBy == request.auth.uid;
    }

    function validEventLifecycleCreate() {
      return request.resource.data.startAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && request.resource.data.expiresAt > request.resource.data.startAt
        && request.resource.data.lifecycleState in ['Scheduled', 'Live', 'Ending'];
    }

    function eventIsHistorical() {
      return resource.data.lifecycleState in ['Canonised', 'Archived']
        || resource.data.canonised == true
        || resource.data.socialLocked == true;
    }

    function eventUpdateDoesNotControlLifecycle() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'startAt',
        'expiresAt',
        'lifecycleState',
        'canonised',
        'canonisedAt',
        'archived',
        'archivedAt',
        'socialLocked',
        'immutable',
        'finalStatistics',
        'historicalMetadata',
        'lockedFields',
        'liveFeedEligible',
        'currentEventEligible',
        'recommendationEligible',
        'commentsEnabled',
        'repliesEnabled',
        'reactionsEnabled',
        'mediaUploadsEnabled',
        'timelineEditsEnabled',
        'metadataEditsEnabled',
        'creatorEditsEnabled',
        'notificationsEnabled',
        'liveMapEnabled'
      ]);
    }

    match /users/{uid} {
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(['displayName', 'email', 'preferences', 'createdAt', 'updatedAt']);
      allow read, delete: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['displayName', 'preferences', 'profilePhotoUrl', 'bannerUrl', 'bio', 'location', 'website', 'pronouns', 'birthdayVisibility', 'profileVisibility', 'updatedAt']);

      match /vortex/{privateDocument=**} {
        allow read, write: if isOwner(uid);
      }

      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'updatedAt'])
          && request.resource.data.read == true;
        allow create, delete: if false;
      }

      match /private/{privateDocument=**} {
        allow read, write: if isOwner(uid);
      }
    }

    match /handles/{handle} {
      allow read, write: if false;
    }

    match /protectedHandles/{handle} { allow read, write: if false; }
    match /reservedHandles/{handle} { allow read, write: if false; }
    match /handlePolicies/{policyId} { allow read, write: if false; }

    match /publicProfiles/{uid} {
      allow read: if true;
      allow write: if false;
    }

    match /handleListings/{listingId} {
      allow read: if signedIn() && (resource.data.listingStatus == 'active'
        || resource.data.sellerUid == request.auth.uid
        || resource.data.buyerUid == request.auth.uid);
      allow write: if false;
    }

    match /handleOffers/{offerId} {
      allow read: if signedIn() && (resource.data.sellerUid == request.auth.uid || resource.data.buyerUid == request.auth.uid);
      allow write: if false;
    }

    match /handleTransactions/{transactionId} {
      allow read: if signedIn() && (resource.data.sellerUid == request.auth.uid || resource.data.buyerUid == request.auth.uid);
      allow write: if false;
    }

    match /handleTransfers/{transferId} {
      allow read: if signedIn() && (resource.data.sellerUid == request.auth.uid || resource.data.buyerUid == request.auth.uid);
      allow write: if false;
    }

    match /handleDisputes/{disputeId} {
      allow read: if signedIn() && resource.data.openedByUid == request.auth.uid;
      allow write: if false;
    }

    match /protectedHandleClaims/{claimId} {
      allow read: if signedIn() && resource.data.claimantUid == request.auth.uid;
      allow write: if false;
    }

    match /handleRequests/{requestId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /handlePurchases/{purchaseId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /handleRiskSignals/{signalId} { allow read, write: if false; }

    match /marketplaceConfig/{configId} { allow read, write: if false; }
    match /platformConfig/{configId} {
      allow read: if isPrivilegedPortalOperator();
      allow write: if false;
    }
    match /auditLogs/{auditId} { allow read, write: if false; }

    match /events/{eventId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.archived == false
        && validEventLifecycleCreate();
      allow update: if isEventCreator()
        && !eventIsHistorical()
        && eventUpdateDoesNotControlLifecycle();
      allow delete: if false;

      match /reports/{reportId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid
          && !(get(/databases/$(database)/documents/events/$(eventId)).data.lifecycleState in ['Canonised', 'Archived'])
          && get(/databases/$(database)/documents/events/$(eventId)).data.socialLocked != true;
        allow update, delete: if signedIn()
          && resource.data.createdBy == request.auth.uid
          && !(get(/databases/$(database)/documents/events/$(eventId)).data.lifecycleState in ['Canonised', 'Archived'])
          && get(/databases/$(database)/documents/events/$(eventId)).data.socialLocked != true;
      }
    }

    match /eventSources/{sourceId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /eventContributions/{contributionId} {
      allow read: if signedIn() && resource.data.visibility == 'public';
      allow write: if false;
    }

    match /eventStatusHistory/{historyId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /eventTimeline/{entryId} {
      allow read: if signedIn() && resource.data.moderationState != 'rejected';
      allow write: if false;
    }

    match /eventRelationships/{relationshipId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /historicalEvents/{eventId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /eventCandidates/{candidateId} { allow read, write: if false; }
    match /eventMergeReviews/{reviewId} { allow read, write: if false; }
    match /ingestionProviders/{providerId} {
      allow read: if isPrivilegedPortalOperator();
      allow write: if false;
    }
    match /ingestionRuns/{runId} {
      allow read: if isPrivilegedPortalOperator();
      allow write: if false;
    }

    match /vortexEntries/{entryId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /posts/{postId} {
      allow read: if signedIn() && resource.data.visibility == 'public';
      allow write: if false;
    }

    match /postViews/{postId}/viewers/{viewerId} {
      allow read: if isPrivilegedPortalOperator();
      allow write: if false;
    }

    match /postEchoes/{echoId} {
      allow read: if signedIn() && resource.data.echoingUid == request.auth.uid;
      allow write: if false;
    }

    match /postLikes/{likeId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /postBookmarks/{bookmarkId} {
      allow read: if signedIn() && resource.data.uid == request.auth.uid;
      allow write: if false;
    }

    match /postReplies/{replyId} {
      allow read: if signedIn() && resource.data.visibility == 'public';
      allow write: if false;
    }

    match /messageConversations/{conversationId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participantUids;
      allow create: if signedIn()
        && request.resource.data.participantUids is list
        && request.resource.data.participantUids.size() == 2
        && request.auth.uid in request.resource.data.participantUids
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'participantUids',
          'participantHandles',
          'participantPhotoUrls',
          'title',
          'createdBy',
          'lastMessage',
          'lastMessageAt',
          'updatedAt',
          'createdAt',
          'pinned',
          'pinnedBy',
          'archivedBy',
          'deletedBy',
          'unreadBy',
          'typingUids'
        ]);
      allow update: if signedIn()
        && request.auth.uid in resource.data.participantUids
        && request.resource.data.participantUids == resource.data.participantUids
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastMessageAt',
          'updatedAt',
          'pinnedBy',
          'archivedBy',
          'deletedBy',
          'unreadBy',
          'typingUids'
        ]);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if signedIn() && request.auth.uid in get(/databases/$(database)/documents/messageConversations/$(conversationId)).data.participantUids;
        allow create: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/messageConversations/$(conversationId)).data.participantUids
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasOnly(['senderUid', 'body', 'media', 'replyTo', 'linkPreview', 'readBy', 'createdAt']);
        allow update: if signedIn()
          && resource.data.senderUid == request.auth.uid
          && request.resource.data.senderUid == resource.data.senderUid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'media', 'deletedByUid', 'deletedAt']);
        allow delete: if false;
      }
    }

    match /quoteEchoes/{quoteEchoId} {
      allow read: if signedIn() && (resource.data.visibility == 'public' || resource.data.quoteAuthorUid == request.auth.uid);
      allow write: if false;
    }

    match /signals/{signalId} {
      allow read: if signedIn() && resource.data.visibility == 'public';
      allow write: if false;
    }
  }
}
