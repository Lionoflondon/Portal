{
  "name": "portal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "guard:isolation": "node scripts/guard-portal-isolation.mjs",
    "build": "npm run guard:isolation && vite build",
    "build:admin": "npm run guard:isolation && vite build --config vite.admin.config.js",
    "verify:admin-deploy": "node scripts/verify-admin-deployment.mjs",
    "deploy:admin": "npm run build:admin && firebase deploy --only hosting:portal-admin --project portal-prod-f2308 && npm run verify:admin-deploy",
    "check:admin-readiness": "node scripts/admin-production-readiness-check.mjs",
    "lint": "eslint .",
    "test": "vitest run src",
    "test:vortex": "node --test functions/entry-engine.test.js",
    "test:identity": "node --test functions/identity-engine.test.js",
    "test:marketplace": "node --test functions/marketplace-engine.test.js",
    "seed:protected-handles": "node functions/scripts/seed-protected-handles.js",
    "test:rules": "firebase emulators:exec --project portal-prod-f2308 --only firestore,storage \"vitest run tests/rules.test.mjs\"",
    "preview": "vite preview",
    "preview:admin": "vite preview --outDir dist-admin"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "firebase": "^11.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "vitest": "^2.1.8"
  }
}
